{
  "name": "clawberto-ton-testnet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ton": "node --import tsx skills/ton-testnet-consensus/scripts/ton_testnet_chat.ts",
    "bootstrap:testnet": "bash skills/ton-testnet-consensus/scripts/bootstrap_testnet_env.sh",
    "probe:testnet": "node --import tsx scripts/testnet_probe.ts",
    "self-faucet:testnet": "node --import tsx scripts/testnet_self_faucet.ts",
    "smoke:testnet": "node --import tsx skills/ton-testnet-consensus/scripts/ton_testnet_smoke.ts",
    "smoke:pinning": "node --import tsx skills/ton-testnet-consensus/scripts/ton_pinning_smoke.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run smoke:testnet && npm run smoke:pinning"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.2",
    "tonweb": "^0.0.66",
    "tweetnacl": "^1.0.3"
  }
}
